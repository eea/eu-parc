{#
/**
 * @file
 * Parc theme implementation for videos grid block.
 */
#}

{%
  set classes = [
    'view-' ~ id|clean_class,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {{ title_suffix }}

  {{ exposed }}
  {{ attachment_before }}

  {% if rows -%}
    {{ rows }}
  {% elseif empty -%}
    <div class="views-empty mb-5">{{ empty }}</div>
  {% endif %}
  {{ pager }}

  {{ attachment_after }}
  {{ more }}
</div>
