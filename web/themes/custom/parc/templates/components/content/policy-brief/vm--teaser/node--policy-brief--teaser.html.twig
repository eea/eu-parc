{#
/**
 * @file
 * Parc override to display a policy brief node teaser.
 */
#}

{{ attach_library('parc/n--policy-brief--teaser') }}

{% set classes = [
  'node',
  'node--' ~ node.bundle|clean_class,
  view_mode ? 'node--' ~ node.bundle|clean_class ~ '--' ~ view_mode|clean_class,
] %}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {{ title_suffix }}

  <div class="node--head d-flex justify-content-between align-items-center mb-2 mb-md-3">
    {% if node.field_d_date.value %}
      {{ content.field_d_date }}
    {% else %}
      <span class="coming-soon">{{ 'Coming soon'|t }}</span>
    {% endif %}
  </div>

  <h5{{ title_attributes.addClass('flex-grow-1') }}>
    {{ label }}
  </h5>

  <div{{ content_attributes.addClass('node--content') }}>
    {{ content|without('field_d_date') }}
  </div>
</article>
