{#
/**
 * @file
 * Parc override to display a taxonomy term.
 */
#}

{{ attach_library('parc/t--thematic-areas--card') }}
{{ attach_library('parc/n--page-full') }}

{%
  set classes = [
    't-term',
    't-term--' ~ term.bundle|clean_class,
    view_mode ? 't-term--' ~ term.bundle|clean_class ~ '--' ~ view_mode|clean_class,
    'svg-hover-effect',
    'position-relative',
    'paragraph--links-list',
  ]
%}

<div{{attributes.setAttribute('id','taxonomy-term-'~term.id).setAttribute('style','--tta--c:'~content.field_color.0|render).addClass(classes)}}>
  {{ title_prefix }}
  {{ title_suffix }}

  {{ content|without('field_color') }}

  <h5 class="card-title stretched-link d-flex justify-content-between">
    {{- name -}}
  </h5>
</div>
