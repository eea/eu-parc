{%
  set classes = [
    'view-' ~ id|clean_class,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
{{ attach_library('parc/svg_title') }}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if title %}
    <div class="svg-title">
      <h1>{{ title }}</h1>
    </div>
  {% endif %}
  {{ title_suffix }}

  {% if header %}
    <header>
      {{ header }}
    </header>
  {% endif %}

  {{ exposed }}
  {{ attachment_before }}

  {% if more %}
    <div class="view-more-link">
      {{ more }}
      <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000" aria-hidden="true"><path d="m560-240-56-58 142-142H160v-80h486L504-662l56-58 240 240-240 240Z"/></svg>
    </div>
  {% endif %}

  {% if rows -%}
    {{ rows }}
  {% elseif empty -%}
    <div class="views-empty mb-5">{{ empty }}</div>
  {% endif %}
  {{ pager }}

  {{ attachment_after }}

  {% if footer %}
    <footer>
      {{ footer }}
    </footer>
  {% endif %}

  {{ feed_icons }}
</div>
